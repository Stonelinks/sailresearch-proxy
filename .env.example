# Required
SAIL_API_KEY=sk-sail-...

# Sail API
SAIL_BASE_URL=https://api.sailresearch.com/v1

# Server
PORT=4000
HOST=0.0.0.0

# Defaults
DEFAULT_COMPLETION_WINDOW=standard
DEFAULT_MODEL=deepseek-ai/DeepSeek-V3.2

# Polling
MAX_POLL_DURATION_MS=900000
POLL_INTERVAL_MS=1000
MAX_CONCURRENT_POLLS=10

# Streaming simulation
STREAM_CHUNK_SIZE=20

# Logging: debug | info (default) | warn | error
LOG_LEVEL=info

# Database (env.sh sets this automatically with absolute path)
# DATABASE_URL=file:/absolute/path/to/data/proxy.db

# Optional: protect the proxy itself
PROXY_API_KEY=
